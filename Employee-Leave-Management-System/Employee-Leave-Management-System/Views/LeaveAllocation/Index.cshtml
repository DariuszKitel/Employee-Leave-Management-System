@model Employee_Leave_Management_System.Models.CreateLeaveAllocationVM

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>


<table class="table">
    <thead>
        <tr>         
            <th>
                Leave Types
            </th>            
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.leaveTypes) {
        <tr>
            
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            
            <td>
                @*@Html.ActionLink("Allocate to Employee", "SetLeave", new { id = item.Id }) *@
                <a class="btn btn-outline-success" asp-action="SetLeave" asp-route-id="@item.Id">
                    <i class="fa fa-pencil"></i>Allocate to Employee
                </a>
            </td>
        </tr>
}
    </tbody>
</table>
